# Telegram bot token from BotFather. Required.
# Keep this secret; never commit a real token.
TELEGRAM_BOT_TOKEN=

# OpenAI API key used by the Responses API client. Required.
# Keep this secret; never commit a real key.
OPENAI_API_KEY=

# OpenAI model used for AI responses and tool calling.
OPENAI_MODEL=gpt-4.1-mini

# Telegram numeric user IDs with full access. Required; comma-separated.
# Example: OWNER_IDS=123456789,987654321
OWNER_IDS=

# Telegram numeric user IDs that can read status/logs and request restart confirmations.
# Leave empty when unused.
ADMIN_IDS=

# Telegram numeric user IDs that can use read-only commands and AI summaries.
# Leave empty when unused.
VIEWER_IDS=

# SQLite database URL for audit events, confirmations, and runtime state.
# Keep the default for Docker Compose so data persists under ./data.
DATABASE_URL=sqlite:///data/serverops.db

# Application log level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# User-facing Telegram language: vi or en.
# Command names, audit action IDs, targets, and confirmation text remain stable.
BOT_LANGUAGE=vi

# One-shot startup validation mode. Set true for smoke checks; false for normal polling.
SERVEROPS_INIT_ONLY=false

# Number of lines returned by host log reads. Bounded by application validation.
LOG_TAIL_LINES=200

# Master gate for Docker commands and Docker AI tools.
# Keep false unless you accept Docker socket exposure and have narrow ALLOWED_CONTAINERS.
ENABLE_DOCKER_TOOLS=false

# Number of lines returned by Docker log reads when Docker tools are enabled.
DOCKER_LOG_TAIL_LINES=200

# Enables scheduled read-only owner alerts for CPU/RAM/disk thresholds.
ENABLE_ALERTS=false

# Alert scheduler interval in seconds.
ALERT_INTERVAL_SECONDS=60

# Cooldown in seconds before the same alert can be sent again.
ALERT_COOLDOWN_SECONDS=900

# CPU usage percentage threshold for owner alerts.
ALERT_CPU_PERCENT=90

# RAM usage percentage threshold for owner alerts.
ALERT_RAM_PERCENT=90

# Disk usage percentage threshold for owner alerts.
ALERT_DISK_PERCENT=90

# Reserved gate for Docker alert checks. Keep false unless Docker alert checks are implemented/enabled.
ALERT_DOCKER_ENABLED=false

# Service names that can be restarted through /restart after confirmation.
# Example: ALLOWED_SERVICES=nginx,postgres
ALLOWED_SERVICES=

# Container names visible to Docker commands and eligible for /docker_restart.
# Requires ENABLE_DOCKER_TOOLS=true.
# Example: ALLOWED_CONTAINERS=nginx,api
ALLOWED_CONTAINERS=

# Host log allowlist as comma-separated name:path entries.
# Paths should match mounted container paths, usually under /host/var/log.
# Example: ALLOWED_LOG_FILES=nginx_errors:/host/var/log/nginx/error.log,app:/app/data/app.log
ALLOWED_LOG_FILES=
